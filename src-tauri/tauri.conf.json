{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Guitar Tuner &amp; Metronome",
  "version": "0.1.0",
  "identifier": "com.guitar.tuner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Guitar Tuner &amp; Metronome",
        "width": 400,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Guitar Tuner &amp; Metronome App",
    "longDescription": "A guitar tuner and metronome app for Android",
    "android": {
      "minSdkVersion": 24
    }
  }
}